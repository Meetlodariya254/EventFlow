rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for schema validation
    function isValidEvent() {
      let data = request.resource.data;
      return data.title is string && data.title.size() > 0 && data.title.size() <= 150
        && data.userId == request.auth.uid
        && data.mobileNumber is string && data.mobileNumber.size() >= 10 && data.mobileNumber.size() <= 20
        && (data.description == null || (data.description is string && data.description.size() <= 1000));
    }

    match /events/{eventId} {
      // Only read if the user owns the document
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow create if the user is authenticated, sets themselves as owner, and data is valid
      allow create: if request.auth != null 
                    && isValidEvent();
                    
      // Allow update if the user owns the existing document, isn't trying to change ownership, and data remains valid
      allow update: if request.auth != null 
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && isValidEvent();
                    
      // Allow delete if the user owns the document
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    match /reminders/{reminderId} {
      // Read access only for the document owner
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Cloud functions handle writes via Admin SDK (bypasses these rules)
      allow write: if false; 
    }
  }
}
